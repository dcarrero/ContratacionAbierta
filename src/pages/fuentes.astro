---
import Layout from '../layouts/Layout.astro'
import { fuentes } from '../data/fuentes'

const nacionales = fuentes.filter(f => f.tipo === 'nacional')
const regionales = fuentes.filter(f => f.tipo === 'regional')
const datasets = fuentes.filter(f => f.tipo === 'dataset')
---

<Layout
  title="Fuentes de datos de contratacion publica y subvenciones en Espana"
  description="Catalogo completo de fuentes oficiales de datos abiertos de contratacion publica y subvenciones: PLACSP, BDNS, APIs regionales, portales de datos abiertos de CCAA y datasets historicos."
>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Fuentes de datos</h1>
    <p class="text-gray-400 mb-12">
      {fuentes.length} fuentes oficiales de contratacion publica y subvenciones en Espana, organizadas por ambito y formato.
    </p>

    <!-- Nacionales -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-1">Fuentes nacionales</h2>
      <p class="text-sm text-gray-500 mb-6">Feeds y APIs del Estado: Plataforma de Contratacion del Sector Publico y Base de Datos Nacional de Subvenciones (Ministerio de Hacienda)</p>

      <div class="space-y-4">
        {nacionales.map(f => (
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-blue-800 transition">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-white"><a href={`/fuentes/${f.id}/`} class="hover:text-blue-300 transition">{f.nombre}</a></h3>
                <p class="text-sm text-gray-400 mt-1">{f.descripcion}</p>
              </div>
              <div class="flex gap-2 shrink-0">
                <a href={f.url_portal} target="_blank" rel="noopener"
                   class="text-xs px-3 py-1.5 bg-gray-800 text-gray-300 rounded hover:bg-gray-700 transition">Portal</a>
                {f.url_datos && (
                  <a href={f.url_datos} target="_blank" rel="noopener"
                     class="text-xs px-3 py-1.5 bg-blue-900/50 text-blue-300 rounded hover:bg-blue-900 transition">Datos</a>
                )}
              </div>
            </div>
            <dl class="mt-3 grid grid-cols-2 sm:grid-cols-5 gap-x-4 gap-y-1 text-xs">
              <div><dt class="text-gray-600 inline">Formato:</dt> <dd class="text-gray-400 inline">{f.formato}</dd></div>
              <div><dt class="text-gray-600 inline">Registros:</dt> <dd class="text-gray-400 inline">{f.registros}</dd></div>
              <div><dt class="text-gray-600 inline">Cobertura:</dt> <dd class="text-gray-400 inline">{f.cobertura}</dd></div>
              <div><dt class="text-gray-600 inline">Actualiz.:</dt> <dd class="text-gray-400 inline">{f.actualizacion}</dd></div>
              <div><dt class="text-gray-600 inline">Licencia:</dt> <dd class="text-gray-400 inline">{f.licencia}</dd></div>
            </dl>
            {f.descargas && f.descargas.length > 0 && (
              <details class="mt-3">
                <summary class="text-xs text-blue-400 cursor-pointer hover:text-blue-300">
                  {f.descargas.length} archivos ZIP disponibles
                </summary>
                <div class="mt-2 flex flex-wrap gap-2">
                  {f.descargas.map(d => (
                    <a href={d.url} target="_blank" rel="noopener"
                       class="text-xs px-2 py-1 bg-gray-800 text-gray-300 rounded hover:bg-gray-700 transition font-mono">
                      {d.periodo}
                    </a>
                  ))}
                </div>
              </details>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Datasets -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-1">Datasets procesados</h2>
      <p class="text-sm text-gray-500 mb-6">Datos historicos recopilados y estructurados, listos para analisis</p>

      <div class="space-y-4">
        {datasets.map(f => (
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-purple-800 transition">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-white"><a href={`/fuentes/${f.id}/`} class="hover:text-blue-300 transition">{f.nombre}</a></h3>
                <p class="text-sm text-gray-400 mt-1">{f.descripcion}</p>
              </div>
              <a href={f.url_datos} target="_blank" rel="noopener"
                 class="text-xs px-3 py-1.5 bg-purple-900/50 text-purple-300 rounded hover:bg-purple-900 transition shrink-0">
                Descargar dataset
              </a>
            </div>
            <dl class="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-x-4 gap-y-1 text-xs">
              <div><dt class="text-gray-600 inline">Formato:</dt> <dd class="text-gray-400 inline">{f.formato}</dd></div>
              <div><dt class="text-gray-600 inline">Registros:</dt> <dd class="text-gray-400 inline">{f.registros}</dd></div>
              <div><dt class="text-gray-600 inline">Cobertura:</dt> <dd class="text-gray-400 inline">{f.cobertura}</dd></div>
              <div><dt class="text-gray-600 inline">Licencia:</dt> <dd class="text-gray-400 inline">{f.licencia}</dd></div>
            </dl>
          </div>
        ))}
      </div>
    </section>

    <!-- Regionales -->
    <section>
      <h2 class="text-xl font-bold text-white mb-1">Fuentes regionales</h2>
      <p class="text-sm text-gray-500 mb-6">Portales de datos abiertos de comunidades autonomas con datos propios de contratacion</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {regionales.map(f => (
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-green-800 transition">
            <h3 class="font-semibold text-white text-sm"><a href={`/fuentes/${f.id}/`} class="hover:text-green-300 transition">{f.nombre}</a></h3>
            <p class="text-xs text-gray-500 mt-0.5">{f.entidad}</p>
            <p class="text-xs text-gray-400 mt-2">{f.descripcion}</p>
            <dl class="mt-2 grid grid-cols-2 gap-x-3 gap-y-0.5 text-xs">
              <div><dt class="text-gray-600 inline">Formato:</dt> <dd class="text-gray-400 inline">{f.formato}</dd></div>
              <div><dt class="text-gray-600 inline">Registros:</dt> <dd class="text-gray-400 inline">{f.registros}</dd></div>
              <div><dt class="text-gray-600 inline">Cobertura:</dt> <dd class="text-gray-400 inline">{f.cobertura}</dd></div>
              <div><dt class="text-gray-600 inline">Actualiz.:</dt> <dd class="text-gray-400 inline">{f.actualizacion}</dd></div>
            </dl>
            <div class="mt-3 flex gap-2">
              <a href={f.url_portal} target="_blank" rel="noopener"
                 class="text-xs px-2 py-1 bg-gray-800 text-gray-300 rounded hover:bg-gray-700 transition">Portal</a>
              {f.url_datos && (
                <a href={f.url_datos} target="_blank" rel="noopener"
                   class="text-xs px-2 py-1 bg-green-900/50 text-green-300 rounded hover:bg-green-900 transition">Datos</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Portales de datos abiertos generales -->
    <section class="mb-16 mt-16">
      <h2 class="text-xl font-bold text-white mb-1">Portales de datos abiertos</h2>
      <p class="text-sm text-gray-500 mb-6">Portales generales de datos abiertos donde buscar datasets de contratacion publica y otros ambitos</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="https://datos.gob.es/es/" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">datos.gob.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Gobierno de Espana</p>
          <p class="text-xs text-gray-400 mt-2">Portal nacional de datos abiertos. Catalogo de mas de 40.000 datasets del sector publico espanol, incluyendo contratacion, presupuestos, empleo y mas.</p>
        </a>

        <a href="https://data.europa.eu/es" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">data.europa.eu</h3>
          <p class="text-xs text-gray-500 mt-0.5">Union Europea</p>
          <p class="text-xs text-gray-400 mt-2">Portal europeo de datos abiertos. Agrega datasets de todos los paises miembros. Incluye TED (Tenders Electronic Daily) con licitaciones europeas.</p>
        </a>

        <a href="https://datos.madrid.es/" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">datos.madrid.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Ayuntamiento de Madrid</p>
          <p class="text-xs text-gray-400 mt-2">Portal de datos abiertos del Ayuntamiento de Madrid. Contratos, presupuestos, padron, transporte y cientos de datasets municipales.</p>
        </a>

        <a href="https://opendata.euskadi.eus" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">opendata.euskadi.eus</h3>
          <p class="text-xs text-gray-500 mt-0.5">Gobierno Vasco</p>
          <p class="text-xs text-gray-400 mt-2">Portal de datos abiertos del Pais Vasco. APIs REST de contratacion, empleo, salud y medio ambiente con acceso libre.</p>
        </a>

        <a href="https://analisi.transparenciacatalunya.cat" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">analisi.transparenciacatalunya.cat</h3>
          <p class="text-xs text-gray-500 mt-0.5">Generalitat de Catalunya</p>
          <p class="text-xs text-gray-400 mt-2">Portal de transparencia de Catalunya con API Socrata. Contratacion publica, presupuestos, subvenciones y mas de 1.000 datasets.</p>
        </a>

        <a href="https://dadesobertes.gva.es" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">dadesobertes.gva.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Generalitat Valenciana</p>
          <p class="text-xs text-gray-400 mt-2">Datos abiertos de la Comunitat Valenciana. Contratacion, sanidad, educacion, transporte y medio ambiente.</p>
        </a>

        <a href="https://datosabiertos.jcyl.es" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">datosabiertos.jcyl.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Junta de Castilla y Leon</p>
          <p class="text-xs text-gray-400 mt-2">Portal de datos abiertos de Castilla y Leon con datasets de contratacion, empleo, turismo y sector agroalimentario.</p>
        </a>

        <a href="https://datos.canarias.es" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">datos.canarias.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Gobierno de Canarias</p>
          <p class="text-xs text-gray-400 mt-2">Portal de datos abiertos de Canarias con datasets de contratacion publica, turismo, territorio y medio ambiente.</p>
        </a>

        <a href="https://www.juntadeandalucia.es/datosabiertos/portal/" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">datosabiertos.juntadeandalucia.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Junta de Andalucia</p>
          <p class="text-xs text-gray-400 mt-2">Portal de datos abiertos de Andalucia. Contratos menores, presupuestos, medio ambiente y mas de 500 datasets en formato CKAN.</p>
        </a>

        <a href="https://opendata.aragon.es" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">opendata.aragon.es</h3>
          <p class="text-xs text-gray-500 mt-0.5">Gobierno de Aragon</p>
          <p class="text-xs text-gray-400 mt-2">Aragon Open Data con datasets de contratacion, presupuestos, territorio y Linked Data con SPARQL endpoint.</p>
        </a>

        <a href="https://datos.gob.es/es/catalogo?theme_id=sector-publico" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">datos.gob.es — Sector publico</h3>
          <p class="text-xs text-gray-500 mt-0.5">Gobierno de Espana</p>
          <p class="text-xs text-gray-400 mt-2">Filtro directo a datasets de sector publico en el portal nacional. Contratacion, empleo publico, patrimonio y organismos.</p>
        </a>

        <a href="https://ted.europa.eu" target="_blank" rel="noopener"
           class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-cyan-700 transition group block">
          <h3 class="font-semibold text-white text-sm group-hover:text-cyan-300 transition">ted.europa.eu</h3>
          <p class="text-xs text-gray-500 mt-0.5">Union Europea — TED</p>
          <p class="text-xs text-gray-400 mt-2">Tenders Electronic Daily: suplemento del Diario Oficial de la UE dedicado a la contratacion publica europea. Licitaciones que superan umbrales comunitarios.</p>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="mt-12 text-center">
      <p class="text-sm text-gray-500">
        Si conoces m&aacute;s fuentes de datos que deber&iacute;an estar aqu&iacute;,
        <a href="https://colorvivo.com/contacto/" target="_blank" rel="noopener" class="text-blue-400 hover:text-blue-300 underline">escr&iacute;benos en nuestro formulario</a>.
      </p>
    </section>

  </div>

</Layout>
