---
import Layout from '../layouts/Layout.astro'
import { fuentes } from '../data/fuentes'

const nacionales = fuentes.filter(f => f.tipo === 'nacional')
const regionales = fuentes.filter(f => f.tipo === 'regional')
const totalDescargas = nacionales.reduce((sum, f) => sum + (f.descargas?.length || 0), 0)
---

<Layout title="Datos Abiertos de Contratacion Publica en Espana">

  <!-- Hero -->
  <header class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-950 via-gray-950 to-gray-950"></div>
    <div class="relative max-w-5xl mx-auto px-4 py-20 sm:py-28 text-center">
      <p class="text-blue-400 font-mono text-sm tracking-widest uppercase mb-4">Catalogo de fuentes de datos</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">
        Contratacion Publica
        <span class="text-blue-400">Abierta</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Todas las fuentes de datos oficiales de contratacion publica en Espana,
        organizadas y listas para descargar. Feeds Atom, APIs REST, CSVs y datasets.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/fuentes/" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition">
          Ver fuentes de datos
        </a>
        <a href="/descargas/" class="px-6 py-3 bg-gray-800 hover:bg-gray-700 text-gray-200 font-semibold rounded-lg border border-gray-700 transition">
          Descargas directas
        </a>
      </div>
    </div>
  </header>

  <!-- Stats -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 text-center">
        <p class="text-3xl font-bold text-white">{nacionales.length}</p>
        <p class="text-sm text-gray-500 mt-1">Feeds nacionales</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 text-center">
        <p class="text-3xl font-bold text-white">{regionales.length}</p>
        <p class="text-sm text-gray-500 mt-1">Fuentes regionales</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 text-center">
        <p class="text-3xl font-bold text-white">~8M</p>
        <p class="text-sm text-gray-500 mt-1">Contratos indexados</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 text-center">
        <p class="text-3xl font-bold text-white">{totalDescargas}</p>
        <p class="text-sm text-gray-500 mt-1">ZIPs descargables</p>
      </div>
    </div>
  </section>

  <!-- Secciones preview -->
  <section class="max-w-5xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

      <a href="/fuentes/" class="group bg-gray-900 border border-gray-800 rounded-lg p-6 hover:border-blue-700 transition block">
        <div class="w-10 h-10 bg-blue-900/50 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-white group-hover:text-blue-300 transition">Fuentes de datos</h3>
        <p class="text-sm text-gray-400 mt-2">
          {fuentes.length} fuentes oficiales de contratacion publica: PLACSP, APIs regionales,
          portales de datos abiertos y datasets historicos.
        </p>
        <p class="text-xs text-blue-400 mt-3 group-hover:text-blue-300">Ver todas las fuentes &rarr;</p>
      </a>

      <a href="/descargas/" class="group bg-gray-900 border border-gray-800 rounded-lg p-6 hover:border-green-700 transition block">
        <div class="w-10 h-10 bg-green-900/50 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-white group-hover:text-green-300 transition">Descargas directas</h3>
        <p class="text-sm text-gray-400 mt-2">
          {totalDescargas} archivos ZIP organizados por tipo y ano. Descarga directa
          desde los servidores oficiales de PLACSP.
        </p>
        <p class="text-xs text-green-400 mt-3 group-hover:text-green-300">Ir a descargas &rarr;</p>
      </a>

      <a href="/portales/" class="group bg-gray-900 border border-gray-800 rounded-lg p-6 hover:border-amber-700 transition block">
        <div class="w-10 h-10 bg-amber-900/50 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-white group-hover:text-amber-300 transition">Portales de consulta</h3>
        <p class="text-sm text-gray-400 mt-2">
          Sitios web con datos publicos ya tratados y listos para consulta libre
          por ciudadanos, periodistas e investigadores.
        </p>
        <p class="text-xs text-amber-400 mt-3 group-hover:text-amber-300">Ver portales &rarr;</p>
      </a>

    </div>
  </section>

  <!-- Referencia a contratacionabierta.es -->
  <section class="max-w-5xl mx-auto px-4 pt-16 pb-4">
    <p class="text-center text-lg text-gray-400">
      Si est&aacute;s buscando
      <a href="https://contratacionabierta.es/?ref=contratacionabierta.com" target="_blank" rel="noopener"
         class="text-blue-400 hover:text-blue-300 underline font-semibold">ContratacionAbierta.es est&aacute; aqu&iacute;</a>.
    </p>
  </section>

  <!-- Que es -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Por que este catalogo</h2>
      <p class="text-gray-400 leading-relaxed">
        Los datos de contratacion publica en Espana estan dispersos entre decenas de portales,
        APIs y formatos diferentes. Este catalogo reune todas las fuentes conocidas en un solo lugar,
        con enlaces directos a los datos originales y archivos listos para descargar.
        Para investigadores, periodistas, desarrolladores y cualquier ciudadano interesado
        en la transparencia de la contratacion publica.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="bg-gradient-to-r from-blue-950 to-gray-900 border border-blue-900/50 rounded-xl p-8 sm:p-12 text-center">
      <h2 class="text-2xl font-bold text-white">Contacto</h2>
      <p class="text-gray-400 mt-2 max-w-lg mx-auto">
        Sugerencias de nuevas fuentes, correcciones de datos o cualquier consulta
        sobre contratacion publica abierta.
      </p>
      <a href="https://colorvivo.com/contacto/" target="_blank" rel="noopener"
         class="inline-block mt-6 px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition">
        Escribenos
      </a>
    </div>
  </section>

</Layout>
