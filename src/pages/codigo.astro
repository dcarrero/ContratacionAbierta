---
import Layout from '../layouts/Layout.astro'

const proyectos = [
  {
    nombre: 'contrataciondelestado',
    autor: 'jvrsantacruz',
    url: 'https://github.com/jvrsantacruz/contrataciondelestado',
    descripcion: 'Parser y scraper de la Plataforma de Contratacion del Estado. Herramientas Python para extraer y procesar datos de licitaciones desde los feeds Atom CODICE.',
    lenguajes: ['Python'],
    tags: ['parser', 'scraper', 'PLACSP', 'CODICE'],
  },
  {
    nombre: 'licitaciones-espana',
    autor: 'BquantFinance',
    url: 'https://github.com/BquantFinance/licitaciones-espana',
    descripcion: 'Dataset de 8,69 millones de registros de licitaciones publicas espanolas en formato Parquet. Recopilado y estructurado para analisis con Python.',
    lenguajes: ['Python', 'Parquet'],
    tags: ['dataset', 'open-data', 'analisis'],
  },
  {
    nombre: 'contractacio.cat',
    autor: 'JaimeObregon',
    url: 'https://github.com/JaimeObregon/contractacio.cat',
    descripcion: 'Codigo fuente del portal contractacio.cat para visualizar y analizar contratos publicos de la Generalitat de Catalunya.',
    lenguajes: ['JavaScript'],
    tags: ['frontend', 'visualizacion', 'Catalunya'],
  },
  {
    nombre: 'contractes-cat',
    autor: 'gerardgimenezadsuar',
    url: 'https://github.com/gerardgimenezadsuar/contractes-cat',
    descripcion: 'Herramientas para trabajar con datos de contratacion publica de Catalunya desde la API Socrata de transparencia.',
    lenguajes: ['Python'],
    tags: ['API', 'Socrata', 'Catalunya'],
  },
  {
    nombre: 'licitaciones-contratos-menores-comunidad-de-madrid',
    autor: 'Naroh091',
    url: 'https://github.com/Naroh091/licitaciones-contratos-menores-comunidad-de-madrid',
    descripcion: 'Scraper y analisis de contratos menores de la Comunidad de Madrid. Extraccion de datos del portal de contratos publicos madrileno.',
    lenguajes: ['Python'],
    tags: ['scraper', 'Madrid', 'contratos-menores'],
  },
]

const referencias = [
  {
    nombre: 'awesome-spain',
    autor: 'GeiserX',
    url: 'https://github.com/GeiserX/awesome-spain',
    descripcion: 'Lista curada de APIs, datasets y recursos de datos abiertos de Espana. Incluye seccion de contratacion publica, datos del INE, catastro y mas.',
    tags: ['awesome-list', 'open-data', 'APIs'],
  },
]
---

<Layout
  title="Codigo y recursos — Proyectos open source de contratacion publica"
  description="Repositorios GitHub, parsers, scrapers y herramientas open source para trabajar con datos de contratacion publica en Espana. Python, JavaScript y mas."
>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Codigo y recursos</h1>
    <p class="text-gray-400 mb-12">
      Proyectos open source, parsers, scrapers y herramientas para trabajar con datos
      de contratacion publica en Espana. Todos en GitHub.
    </p>

    <!-- Proyectos -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-1">Proyectos de contratacion publica</h2>
      <p class="text-sm text-gray-500 mb-6">Repositorios con codigo para extraer, procesar y visualizar datos de contratacion</p>

      <div class="space-y-4">
        {proyectos.map(p => (
          <a href={p.url} target="_blank" rel="noopener"
             class="block bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-blue-700 transition group">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"></path>
                  </svg>
                  <h3 class="font-semibold text-white group-hover:text-blue-300 transition">{p.autor}/{p.nombre}</h3>
                </div>
                <p class="text-sm text-gray-400 mt-2">{p.descripcion}</p>
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {p.lenguajes.map(l => (
                <span class="text-xs px-2 py-0.5 bg-blue-900/30 text-blue-300 rounded">{l}</span>
              ))}
              {p.tags.map(t => (
                <span class="text-xs px-2 py-0.5 bg-gray-800 text-gray-500 rounded">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Referencias -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-1">Listas de referencia</h2>
      <p class="text-sm text-gray-500 mb-6">Recursos curados con mas fuentes de datos y APIs de Espana</p>

      <div class="space-y-4">
        {referencias.map(r => (
          <a href={r.url} target="_blank" rel="noopener"
             class="block bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-amber-700 transition group">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"></path>
              </svg>
              <h3 class="font-semibold text-white group-hover:text-amber-300 transition">{r.autor}/{r.nombre}</h3>
            </div>
            <p class="text-sm text-gray-400 mt-2">{r.descripcion}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {r.tags.map(t => (
                <span class="text-xs px-2 py-0.5 bg-gray-800 text-gray-500 rounded">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="bg-gray-900/50 border border-dashed border-gray-700 rounded-lg p-8 text-center">
      <h3 class="text-lg font-semibold text-gray-400">Tu proyecto aqui</h3>
      <p class="text-sm text-gray-600 mt-2 max-w-md mx-auto">
        Si tienes un proyecto open source relacionado con contratacion publica en Espana,
        <a href="https://colorvivo.com/contacto/" target="_blank" rel="noopener" class="text-blue-400 hover:text-blue-300 underline">contactanos</a> para incluirlo.
      </p>
    </div>

  </div>

</Layout>
